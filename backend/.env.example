# =============================================================================
# Quiz-App Backend — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.
# =============================================================================

# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development   # Set to "production" on live servers

# ── MongoDB ──────────────────────────────────────────────────────────────────
# Connection string from MongoDB Atlas or your self-hosted instance
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGO_URI=

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Minimum 64 hex characters (256 bits). Must be random and unique per environment.
JWT_SECRET=

# ── Super Admin ──────────────────────────────────────────────────────────────
# Username for the platform-wide super admin account
SUPER_ADMIN_USERNAME=superadmin

# Password: minimum 12 characters, mix of upper/lower/numbers/symbols
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('base64url'))"
SUPER_ADMIN_PASSWORD=

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# OPTION A (Production): Store the full JSON content of serviceAccountKey.json
# as a single-line JSON string in this env var. Never commit the .json file.
# To generate: cat serviceAccountKey.json | jq -c . (then paste the output here)
FIREBASE_SERVICE_ACCOUNT=

# OPTION B (Local Dev only): Path to the local service account key file
# Comment this out in production — use FIREBASE_SERVICE_ACCOUNT instead
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
# Example: https://quiz-app-3e991.web.app,https://quiz-app-3e991.firebaseapp.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000,http://localhost:5500

# ── Cookie Security ──────────────────────────────────────────────────────────
# Set to "true" in production (requires HTTPS). "false" for local HTTP dev.
COOKIE_SECURE=false

# ── Session / Token TTL ──────────────────────────────────────────────────────
JWT_EXPIRES_IN=1d
STUDENT_JWT_EXPIRES_IN=4h
