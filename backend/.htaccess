# ── Hostinger/LiteSpeed Fixes ──────────────────────────────────────────

# 1. Ensure Authorization Header is passed to Node.js (LiteSpeed strips it otherwise)
RewriteEngine On
RewriteCond %{HTTP:Authorization} ^(.+)$
RewriteRule .* - [E=HTTP_AUTHORIZATION:%1]

# NOTE: Do NOT intercept OPTIONS here.
# If OPTIONS is caught by RewriteRule and returned as 204, Apache/LiteSpeed
# sends the 204 WITHOUT CORS headers, which is what causes the CORS error.
# Let all requests (including OPTIONS) pass through to Node.js instead.
