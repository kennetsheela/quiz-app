# ── LiteSpeed/Apache CORS Fix for Hostinger Node.js ──────────────────────
#
# IMPORTANT: mod_headers directives MUST come before RewriteEngine for 
# LiteSpeed to apply them to internally-generated (RewriteRule) responses.
#

<IfModule mod_headers.c>
    # These headers apply to ALL responses including OPTIONS rewrite below
    Header always set Access-Control-Allow-Origin "https://aptiogen-56f98.web.app"
    Header always set Access-Control-Allow-Methods "GET, POST, OPTIONS, PUT, DELETE, PATCH"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With, Accept, Origin"
    Header always set Access-Control-Allow-Credentials "true"
    Header always set Access-Control-Max-Age "3600"
</IfModule>

RewriteEngine On

# Pass Authorization header through to Node.js (LiteSpeed strips it by default)
RewriteCond %{HTTP:Authorization} ^(.+)$
RewriteRule .* - [E=HTTP_AUTHORIZATION:%1]

# Handle OPTIONS preflight: return 200 with headers above already set
RewriteCond %{REQUEST_METHOD} ^OPTIONS$
RewriteRule .* - [R=200,L]
